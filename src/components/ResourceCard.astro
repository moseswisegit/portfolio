---
import { ExternalLink, Bookmark, User } from 'lucide-react';
import type { Resource } from '../data/ressources';

interface Props {
  resource: Resource;
}

const { resource } = Astro.props;

const categoryColors = {
  Frontend: 'text-blue-700 bg-blue-50 dark:text-blue-400 dark:bg-blue-400/10',
  Backend: 'text-green-700 bg-green-50 dark:text-green-400 dark:bg-green-400/10',
  Mobile: 'text-purple-700 bg-purple-50 dark:text-purple-400 dark:bg-purple-400/10',
  DevOps: 'text-orange-700 bg-orange-50 dark:text-orange-400 dark:bg-orange-400/10',
  Architecture: 'text-cyan-700 bg-cyan-50 dark:text-cyan-400 dark:bg-cyan-400/10',
  UX: 'text-pink-700 bg-pink-50 dark:text-pink-400 dark:bg-pink-400/10',
};

const categoryImages = {
  Frontend: '/portfolio/images/categories/frontend.png',
  Backend: '/portfolio/images/categories/backend.png',
  Mobile: '/portfolio/images/categories/mobile.png',
  DevOps: '/portfolio/images/categories/architecture.png',
  Architecture: '/portfolio/images/categories/architecture.png',
  UX: '/portfolio/images/categories/ux.png',
};
---

<div class="glow-card group flex flex-col h-full bg-[var(--card-bg)] border-[var(--border-primary)] overflow-hidden">
  <!-- Image Section -->
  <div class="relative aspect-video overflow-hidden bg-gray-100 dark:bg-gray-900 border-b border-[var(--border-primary)]">
    <img 
      src={resource.image || categoryImages[resource.category]} 
      alt={resource.title} 
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
    />
    <div class="absolute inset-0 bg-black/5 group-hover:bg-black/0 transition-colors"></div>
    <div class="absolute top-3 left-3">
      <span class={`px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider ${categoryColors[resource.category]} shadow-sm backdrop-blur-md`}>
        {resource.category}
      </span>
    </div>
    <div class="absolute top-3 right-3">
      <a 
        href={resource.url} 
        target="_blank" 
        rel="noopener noreferrer"
        class="p-2 rounded-full bg-white/80 dark:bg-black/80 text-[var(--text-primary)] hover:text-[var(--acc-blue)] transition-all shadow-md backdrop-blur-md opacity-0 group-hover:opacity-100 transform translate-y-[-10px] group-hover:translate-y-0"
        aria-label={`Ouvrir ${resource.title}`}
      >
        <ExternalLink size={16} />
      </a>
    </div>
  </div>

  <!-- Content Section -->
  <div class="p-5 flex flex-col flex-grow">
    <h3 class="text-xl font-bold mb-2 text-[var(--text-primary)] group-hover:text-[var(--acc-blue)] transition-colors line-clamp-1">
      {resource.title}
    </h3>

    <p class="text-[var(--text-secondary)] text-sm mb-4 line-clamp-2">
      {resource.description}
    </p>

    <div class="space-y-4 mt-auto">
      <div class="bg-[var(--text-primary)]/[0.03] dark:bg-white/5 rounded-lg p-3 border border-[var(--border-primary)] italic text-sm text-[var(--text-secondary)]">
        <div class="flex items-center gap-2 mb-1 text-[var(--text-secondary)] opacity-60 not-italic font-medium uppercase tracking-wider text-[10px]">
          <User size={12} />
          Note Personnelle
        </div>
        <span class="line-clamp-3">"{resource.note}"</span>
      </div>

      <div class="flex flex-wrap gap-2">
        {resource.tags.slice(0, 3).map(tag => (
          <span class="text-[10px] px-2 py-0.5 rounded border border-[var(--border-primary)] text-[var(--text-secondary)] lowercase">
            #{tag}
          </span>
        ))}
      </div>
    </div>
  </div>
</div>

